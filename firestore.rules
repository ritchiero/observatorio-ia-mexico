rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // The public site reads through sanitized Next.js API routes. Mutations and
    // administrative reads use Firebase Admin on the server, which bypasses
    // client Security Rules after the application-level authorization check.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
